# Environment Selection
NODE_ENV=development
PORT=5000

# -----------------
# Database Configuration
# -----------------
# Best Practice defaults: Database names should be lowercase with hyphens.
# Separate databases per environment (e.g., the-quad-dev, the-quad-staging, the-quad-prod)

# For LOCAL Development (Local MongoDB instance or Docker container)
MONGO_URI=mongodb://localhost:27017/the-quad-dev

# For MongoDB ATLAS (Cloud database - uncomment below and adjust credentials)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/the-quad-dev?retryWrites=true&w=majority

# -----------------
# Secrets
# -----------------
JWT_SECRET=super_secret_jwt_key_example_change_me
