<style>
  body { font-family: 'Inter', Arial, sans-serif; background-color: #0f0f1a; color: #e2e8f0; padding: 20px; }
  .container { max-width: 600px; margin: 0 auto; background-color: #1e1e2f; border-radius: 12px; padding: 30px; }
  .ticket { background-color: #2a2a40; border-radius: 12px; overflow: hidden; margin: 20px 0; border: 1px solid #3f3f5a; }
  .ticket-img { w-full; height: 180px; background-color: #6366f1; background-image: url('{{coverImage}}'); background-size: cover; background-position: center; }
  .ticket-content { padding: 20px; text-align: left; }
  .btn { display: inline-block; padding: 12px 24px; background-color: #10b981; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: bold; width: 100%; text-align: center; box-sizing: border-box; }
</style>
<div class="container">
  <h2 style="color: #10b981; text-align: center;">✅ RSVP Confirmed!</h2>
  <p style="text-align: center; color: #94a3b8;">You are officially on the list for <b>{{title}}</b>.</p>

  <div class="ticket">
    <div class="ticket-img"></div>
    <div class="ticket-content">
      <h3 style="margin-top: 0; font-size: 20px;">{{title}}</h3>
      <p style="margin: 4px 0; color: #cbd5e1;">📅 {{date}} at {{time}}</p>
      <p style="margin: 4px 0; color: #cbd5e1;">📍 {{location}}</p>
      
      <div style="background: #ffffff; padding: 15px; border-radius: 8px; text-align: center; margin-top: 20px;">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={{qrData}}" alt="QR Code" width="150" height="150" />
        <p style="color: #000; font-size: 11px; margin-top: 10px; font-weight: bold;">Scan at door for entry ({{qrSecretToken}})</p>
      </div>
    </div>
  </div>

  <div style="display: flex; gap: 10px; justify-content: center; margin-top: 20px;">
     <a href="{{calendarUrl}}" style="color: #10b981; font-weight: bold; text-decoration: none;">Download .ICS</a>
     <span style="color: #3f3f5a;">|</span>
     <a href="{{cancelUrl}}" style="color: #ef4444; font-weight: bold; text-decoration: none;">Cancel RSVP</a>
  </div>
</div>
